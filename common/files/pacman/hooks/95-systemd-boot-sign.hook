[Trigger]
Type = Package
Operation = Install
Operation = Upgrade
Target = systemd

[Action]
Description = Signing systemd-boot for Secure Boot...
When = PostTransaction
Exec = /bin/sh -c '/usr/lib/systemd/systemd-sbsign sign --private-key /var/lib/secure-boot-keys/secure-boot-private-key.pem --certificate /var/lib/secure-boot-keys/secure-boot-certificate.pem --output /usr/lib/systemd/boot/efi/systemd-bootx64.efi.signed /usr/lib/systemd/boot/efi/systemd-bootx64.efi && bootctl update'
